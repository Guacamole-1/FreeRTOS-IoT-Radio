#-----------------------------------------------------------
# Project
#-----------------------------------------------------------
PROJECT_NAME           = "LPC1769 Embedded Systems for IoT Driver Library"
PROJECT_BRIEF          = "Board Support Package (BSP) and Device Drivers for LPC1769"
PROJECT_NUMBER         = 2026
OUTPUT_DIRECTORY       = .
CREATE_SUBDIRS         = NO

#-----------------------------------------------------------
# Input
#-----------------------------------------------------------
INPUT                  = ../DRIVERS/inc ./README.md 
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.c *.md
USE_MDFILE_AS_MAINPAGE = README.md

#-----------------------------------------------------------
# Output
#-----------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html-api
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
TREEVIEW_WIDTH         = 300
DISABLE_INDEX          = YES

#-----------------------------------------------------------
# SOURCE CODE HIDDEN (CRıTICO)
#-----------------------------------------------------------
SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO
VERBATIM_HEADERS       = NO
STRIP_CODE_COMMENTS    = YES
SHOW_INCLUDE_FILES     = NO
SHOW_FILES             = NO

#-----------------------------------------------------------
# API ONLY (sı o que os alunos devem ver)
#-----------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_SCOPE_NAMES       = YES

#-----------------------------------------------------------
# Organizaııo da documentaııo
#-----------------------------------------------------------
SHOW_NAMESPACES        = NO
SHOW_GROUPED_MEMB_INC  = NO
DISTRIBUTE_GROUP_DOC   = YES
SORT_MEMBER_DOCS       = YES
GROUP_NESTED_COMPOUNDS = YES
SORT_GROUP_NAMES       = YES

#-----------------------------------------------------------
# Source parsing (necessırio para extrair a API)
#-----------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES

#-----------------------------------------------------------
# Warnings
#-----------------------------------------------------------
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

#-----------------------------------------------------------
# Diagrams (sem mostrar cıdigo)
#-----------------------------------------------------------
HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = NO

#-----------------------------------------------------------
# Look & Feel
#-----------------------------------------------------------
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TODOLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_TESTLIST      = YES
