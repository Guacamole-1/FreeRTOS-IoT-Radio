#include "FreeRTOS.h"

/* Kernel includes. */
#include "task.h"
#include "queue.h"

#include "display.h"
#include "delay.h"
#include "lcdtext.h"

static QueueHandle_t disp_queue;

DISPLAY_STATUS DISPLAY_Init(){
	if(!DELAY_Init()){
		return DISP_INIT_ERROR;
	}
	disp_queue = xQueueCreate(DISPLAY_MAX_QUEUE,sizeof(DISPLAY_Item));
	if (disp_queue == NULL){
		return DISP_QUEUE_ERROR;
	}

}

